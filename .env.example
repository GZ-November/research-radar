# 运行环境：development / test / production
APP_ENV=development
# SQLite 数据库文件位置
DATABASE_URL=sqlite:///data/research_radar.db

# ---- 远程分析模型（DeepSeek 示例）----
# 填了 LOCAL_LLM_MODEL 时优先走本地模型，下面远程配置作为备选
LLM_PROVIDER=deepseek
# 你的 API 密钥（注意保密，不要提交到 git）
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
# 是否开启深度思考：enabled / disabled
LLM_THINKING=enabled
# 推理强度：high / max
LLM_REASONING_EFFORT=high
# 单次调用最大输出 token 数
LLM_MAX_TOKENS=4096
# 远程调用超时秒数（与代码默认值一致）
LLM_TIMEOUT_SECONDS=120

# ---- 本地分析模型（Ollama，文稿不出本机；配置后优先于远程）----
# 留空则使用上面的远程模型；示例：qwen3:4b
LOCAL_LLM_MODEL=
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_TIMEOUT_SECONDS=300

# ---- 向量模型（embedding，可选；不配置也能用，只是检索退化为纯关键词）----
# 方式一：本地 Ollama（向量不出本机，无需 API Key）
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# EMBEDDING_BASE_URL=http://127.0.0.1:11434
# 方式二：远程 OpenAI-compatible API（OpenAI / SiliconFlow / Jina 等）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# 注意：EMBEDDING_PROVIDER 留空即关闭向量检索
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
# 向量请求超时秒数与 429/5xx 最大重试次数（指数退避）
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3

# 数据目录（论文、快照、缓存）
DATA_DIR=data
# 演示用例数据目录
FIXTURE_CASE_DIR=tests/fixtures/golden_case
# 发送给 Crossref API 的联系邮箱（礼貌池），建议填真实邮箱
CROSSREF_MAILTO=local@example.invalid
